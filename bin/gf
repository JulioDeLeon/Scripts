#!/usr/bin/env perl
use strict;
use warnings;
use lib 'lib';

# Import the modular components
use GF::Help qw(show_usage show_help show_version show_usage_and_exit);
use GF::Config qw(lookup_config_file);
use GF::Search qw(process_args main_search print_targets);
use GF::Startup qw(initialize_gf_system);

# Global variables
my($term, %ignores, %targets, $context, $maxline, $debug);

# Handle case where no arguments are provided at all
if (@ARGV == 0) {
  print STDERR "Error: No arguments provided.\n";
  print STDERR "\n";
  show_usage();
  exit 1;
}

# Process command line arguments first - help requests are handled here
($term, my $ignores_ref, my $targets_ref, $context, $maxline, $debug) = process_args();
%ignores = %$ignores_ref;
%targets = %$targets_ref;

# Print debug information about targets and ignores
print_targets(\%ignores, \%targets, $debug);

# Load configuration files
lookup_config_file(\%ignores, \%targets, $debug);

# Initialize the gf system with pattern compilation and configuration caching
eval {
  initialize_gf_system($term, \%ignores, \%targets, $context, $maxline, $debug);
};
if ($@) {
  print STDERR "Initialization Error: $@\n";
  exit 1;
}

# Execute main search functionality
main_search($term, \%ignores, \%targets, $context, $maxline, $debug);
